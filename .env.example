# Base de datos (connection pooler - para queries)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa (para migraciones)
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# NextAuth – genera un secreto con: openssl rand -hex 32
AUTH_SECRET="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# URL pública de la aplicación (sin trailing slash)
NEXTAUTH_URL="https://tu-dominio.com"

# Supabase (para Realtime en páginas públicas)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
